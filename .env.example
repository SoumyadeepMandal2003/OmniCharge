# ─────────────────────────────────────────────────────────────────────────────
# OmniCharge Environment Variables
# Copy this file to .env and fill in your values
#   cp .env.example .env
# NEVER commit .env to git!
# ─────────────────────────────────────────────────────────────────────────────

# MySQL
MYSQL_ROOT_PASSWORD=change_this_root_password
MYSQL_USER=omnicharge
MYSQL_PASSWORD=change_this_db_password

# RabbitMQ
RABBITMQ_USER=omnicharge
RABBITMQ_PASSWORD=change_this_rabbit_password

# JWT — must be a long random string (min 32 chars)
JWT_SECRET=change_this_to_a_very_long_random_secret_key_min_32_chars

# Internal service-to-service secret
INTERNAL_SECRET=change_this_internal_secret
